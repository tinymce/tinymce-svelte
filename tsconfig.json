{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "types": ["svelte"],
    "ignoreDeprecations": "5.0",
    "noImplicitAny": false,
    "verbatimModuleSyntax": true,
    "target": "es2022"
  },

  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules/*", "__sapper__/*", "public/*"]
}