 {
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "types": ["svelte"],
    "ignoreDeprecations": "5.0",
    "noImplicitAny": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": ["node_modules/*", "__sapper__/*", "public/*"]
}